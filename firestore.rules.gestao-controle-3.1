rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAutenticado() {
      return request.auth != null;
    }

    function getRole() {
      return exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) ?
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role : null;
    }
    function isAdmin() {
      return getRole() == 'admin' || (request.auth != null && request.auth.token.email == 'admin@logpets.com');
    }
    function isMotorista() {
      return getRole() == 'motorista';
    }

    function getDocaRole(appId) {
      return exists(/databases/$(database)/documents/artifacts/$(appId)/public/data/user_profiles/$(request.auth.uid))
        ? get(/databases/$(database)/documents/artifacts/$(appId)/public/data/user_profiles/$(request.auth.uid)).data.role
        : null;
    }
    function isDocaAdmin(appId) {
      return getDocaRole(appId) == 'admin';
    }

    match /usuarios/{userId} {
      allow read: if isAutenticado();
      allow create: if isAutenticado() && request.auth.uid == userId;
      allow update, delete: if isAutenticado() && isAdmin();
    }

    match /veiculos/{veiculoId} {
      allow read: if isAutenticado();
      allow write: if isAutenticado() && isAdmin();
    }
    match /motoristas/{motoristaId} {
      allow read: if isAutenticado();
      allow write: if isAutenticado() && isAdmin();
    }

    match /clientes/{clienteId} {
      allow read: if isAutenticado();
      allow write: if isAutenticado() && isAdmin();
    }

    match /viagens/{viagemId} {
      allow read: if true;
      allow create, delete: if isAutenticado() && isAdmin();
      allow update: if isAutenticado() && (
        isAdmin() ||
        (resource.data.motoristasIds.hasAny([request.auth.uid]))
      );
    }

    match /manutencoes/{manutencaoId} {
      allow read, write: if isAutenticado() && isAdmin();
    }

    match /financeiro_lancamentos/{lancamentoId} {
      allow read, update, delete: if isAutenticado() && isAdmin();
      allow create: if isAutenticado();
    }

    match /operators/{operatorId} { allow read, create: if true; }
    match /inventory/{itemId} { allow read, write: if true; }
    match /purchaseOrders/{poId} { allow read, write: if true; }
    match /salesOrders/{soId} { allow read, write: if true; }
    match /cycleCountTasks/{taskId} { allow read, write: if true; }
    match /activityLog/{logId} { allow read, create: if true; }
    match /performanceLog/{logId} { allow read, create: if true; }
    match /stats/{statId} { allow read, write: if true; }

    match /landingPage/{docId} {
      allow read: if true;
      allow write: if isAutenticado();
    }

    match /tenants/{tenantId} {
      allow read: if true;
      allow create: if isAutenticado() && request.auth.token.email == 'superadmin@system.com';
      allow update, delete: if isAutenticado() &&
                            (get(/databases/$(database)/documents/tenants/$(tenantId)).data.email == request.auth.token.email || request.auth.token.email == 'superadmin@system.com');

      match /appointments/{appointmentId} {
        allow create, read: if true;
        allow update, delete: if isAutenticado() &&
                              (get(/databases/$(database)/documents/tenants/$(tenantId)).data.email == request.auth.token.email || request.auth.token.email == 'superadmin@system.com');
      }

      match /{otherSubcollection}/{docId} {
        allow read: if true;
        allow write: if isAutenticado() &&
                      (get(/databases/$(database)/documents/tenants/$(tenantId)).data.email == request.auth.token.email || request.auth.token.email == 'superadmin@system.com');
      }
    }

    match /broadcast_messages/{messageId} {
      allow read: if isAutenticado();
      allow create: if request.auth.token.email == 'superadmin@system.com';
    }

    match /cardapio/{itemId} {
      allow read: if true;
      allow write: if isAutenticado();
    }
    match /mesas/{mesaId} { allow read, write: if true; }
    match /pedidos/{pedidoId} {
      allow create, read: if true;
      allow update, delete: if isAutenticado();
    }

    match /artifacts/{appId}/users/{userId}/{documents=**} {
      allow read, write: if isAutenticado() && request.auth.uid == userId;
    }

    match /artifacts/{appId}/public/data {

      match /user_profiles/{userId} {
        allow read: if isAutenticado();
        allow write: if isAutenticado() && (request.auth.uid == userId || isDocaAdmin(appId));
      }

      match /lojas/{docId} {
        allow read: if isAutenticado();
        allow write: if isAutenticado() && isDocaAdmin(appId);
      }
      match /configuracoes/{docId} {
        allow read: if isAutenticado();
        allow write: if isAutenticado() && isDocaAdmin(appId);
      }

      match /registros/{docId} { allow read, write: if isAutenticado(); }
      match /relatorios/{docId} { allow read, write: if isAutenticado(); }
      match /prestadores/{docId} { allow read, write: if isAutenticado(); }
      match /colaboradores_provisorios/{docId} { allow read, write: if isAutenticado(); }
      match /registros_acesso_colaboradores/{docId} { allow read, write: if isAutenticado(); }
      match /emprestimos/{docId} { allow read, write: if isAutenticado(); }
      match /ordens_servico/{docId} { allow read, write: if isAutenticado(); }

      match /areas_criticas/{docId} { allow read, write: if isAutenticado(); }
      match /rondas_historico/{docId} { allow read, write: if isAutenticado(); }
      match /relatorios_supervisor/{docId} { allow read, write: if isAutenticado(); }

      match /almoxarifado_itens/{docId} { allow read, write: if isAutenticado(); }
      match /almoxarifado_movimentacoes/{docId} { allow read, write: if isAutenticado(); }
      match /notas_despesas/{docId} { allow read, write: if isAutenticado(); }
      match /chaves_inventario/{docId} { allow read, write: if isAutenticado(); }
      match /chaves_historico/{docId} { allow read, write: if isAutenticado(); }

      match /veiculos_entradas/{docId} { allow read, write: if isAutenticado(); }
      match /prestadores_servico/{docId} { allow read, write: if isAutenticado(); }
      match /colaboradores_lojas/{docId} { allow read, write: if isAutenticado(); }
      match /equipamentos_emprestados/{docId} { allow read, write: if isAutenticado(); }
      match /emprestimos_diversos/{docId} { allow read, write: if isAutenticado(); }
      match /auditoria_admin/{docId} { allow read, write: if isAutenticado(); }
      match /chat_sessions/{docId} { allow read, write: if isAutenticado(); }

      match /{chatCollection}/{docId} {
        allow read, write: if isAutenticado() && chatCollection.matches('chats_.*');
      }
    }

    match /artifacts/{appId}/public/data/{anyDocument=**} {
      allow read, write: if isAutenticado();
    }

    match /students/{studentId} {
      allow read, write: if true;
    }
    match /logs/{logId} {
      allow read, write: if true;
    }

    match /vistorias/{laudoId} {
      allow read, update, delete: if isAutenticado()
                                  && request.auth.token.email_verified == true
                                  && resource.data.userId == request.auth.uid;

      allow create: if isAutenticado()
                      && request.auth.token.email_verified == true
                      && request.resource.data.userId == request.auth.uid;
    }
  }
}
